#!/bin/bash

IF_LAN="eth1"  # Interface connected to the LAN (Corporate Network)
IF_DMZ="eth2"  # Interface connected to the DMZ (Web Server)
IF_WAN="eth0"  # Interface connected to Switch 2 (Facing the Internet)


LAN_NET="192.168.120.0/24"
DMZ_NET="192.168.20.0/24"
WEB_SERVER="192.168.20.50"

echo "=== INITIALIZING IPTABLES CONFIGURATION FOR ROUTER 1 ==="

# =====================================================================
# 2. FLUSH AND RESET SYSTEM RULES (RESET FIREWALL)
# =====================================================================
iptables -F
iptables -X
iptables -t nat -F
iptables -t nat -X

# =====================================================================
# 3. DEFAULT POLICIES -> DROP ALL FOR MAXIMUM SECURITY
# =====================================================================
iptables -P INPUT DROP
iptables -P FORWARD DROP
iptables -P OUTPUT DROP

# =====================================================================
# 4. CONNECTION STATE MANAGEMENT (STATEFUL INSPECTION)
# Automatically allow response packets (ESTABLISHED, RELATED) to pass through
# =====================================================================
iptables -A INPUT -m conntrack --state ESTABLISHED,RELATED -j ACCEPT
iptables -A FORWARD -m conntrack --state ESTABLISHED,RELATED -j ACCEPT
iptables -A OUTPUT -m conntrack --state ESTABLISHED,RELATED -j ACCEPT

# =====================================================================
# 5. FIREWALL SELF-TRAFFIC CONFIGURATION (INPUT / OUTPUT)
# =====================================================================
# - Allow the firewall to communicate with itself via the Loopback interface
iptables -A INPUT -i lo -j ACCEPT
iptables -A OUTPUT -o lo -j ACCEPT

# - Block all other traffic attempting to initiate a direct connection to the Firewall
# (Explicitly handled by the default INPUT DROP policy above)

# =====================================================================
# 6. FORWARD CHAIN CONFIGURATION FOR NETWORK ZONES
# =====================================================================

# --- DOS ATTACK MITIGATION / NETWORK SECURITY ---
# Drop any invalid packets immediately (Protects against fragmented Ping of Death)
iptables -A FORWARD -m conntrack --state INVALID -j DROP

# Rate-limit incoming TCP SYN packets to mitigate SYN-Flood attacks
iptables -N SYN_FLOOD
iptables -A FORWARD -p tcp --syn -j SYN_FLOOD
iptables -A SYN_FLOOD -m limit --limit 1/s --limit-burst 3 -j RETURN
iptables -A SYN_FLOOD -j DROP


# --- DNS SERVICES ---
# Allow LAN hosts to send DNS queries to external DNS servers on the Internet
iptables -A FORWARD -i $IF_LAN -o $IF_WAN -s $LAN_NET -p udp --dport 53 -m conntrack --state NEW -j ACCEPT
iptables -A FORWARD -i $IF_LAN -o $IF_WAN -s $LAN_NET -p tcp --dport 53 -m conntrack --state NEW -j ACCEPT


# --- SSH SERVICES ---
# 1. Allow LAN hosts to establish SSH connections to hosts inside the DMZ
iptables -A FORWARD -i $IF_LAN -o $IF_DMZ -s $LAN_NET -d $DMZ_NET -p tcp --dport 22 -m conntrack --state NEW -j ACCEPT

# 2. STRICTLY PROHIBIT LAN hosts from initiating SSH connections to the Internet
iptables -A FORWARD -i $IF_LAN -o $IF_WAN -s $LAN_NET -p tcp --dport 22 -j DROP


# --- WEB SERVICES (HTTP/HTTPS) ---
# 1. Allow Internet hosts to connect using HTTP (Port 80) to the Web Server running in the DMZ
iptables -A FORWARD -i $IF_WAN -o $IF_DMZ -d $WEB_SERVER -p tcp --dport 80 -m conntrack --state NEW -j ACCEPT

# 2. Allow LAN hosts to initiate Web connections (HTTP/HTTPS) to the Internet and DMZ
iptables -A FORWARD -i $IF_LAN -s $LAN_NET -p tcp --dport 80 -m conntrack --state NEW -j ACCEPT
iptables -A FORWARD -i $IF_LAN -s $LAN_NET -p tcp --dport 443 -m conntrack --state NEW -j ACCEPT


# --- ICMP PROTOCOL MANAGEMENT (PING & NETWORK DIAGNOSTICS) ---
# Allow essential ICMP types required for proper network operations and PMTUD
iptables -A FORWARD -p icmp --icmp-type destination-unreachable -j ACCEPT
iptables -A FORWARD -p icmp --icmp-type time-exceeded -j ACCEPT
iptables -A FORWARD -p icmp --icmp-type echo-reply -j ACCEPT

# Allow LAN hosts to send ICMP Echo Requests (Ping) out to any destination safely
iptables -A FORWARD -i $IF_LAN -p icmp --icmp-type echo-request -m limit --limit 2/s --limit-burst 5 -j ACCEPT

# 3. Ban DMZ and Internet to send ping to LAN
iptables -A FORWARD -i $IF_DMZ -o $IF_LAN -p icmp --icmp-type echo-request -j DROP
iptables -A FORWARD -i $IF_WAN -o $IF_LAN -p icmp --icmp-type echo-request -j DROP

# --- WAN (INTERNET) TRAFFIC POLICY ---
# Allow external hosts to connect using HTTP (Port 80) to the Web Server inside DMZ
iptables -A FORWARD -i $IF_WAN -o $IF_DMZ -d $WEB_SERVER -p tcp --dport 80 -m conntrack --ctstate NEW -j ACCEPT


# =====================================================================
# 7. NAT ROUTING CONFIGURATION (NAT TABLE)
# =====================================================================
# - Source NAT (MASQUERADE): Translate internal LAN IPs to the WAN IP when accessing the Internet
iptables -t nat -A POSTROUTING -o $IF_WAN -s $LAN_NET -j MASQUERADE

# - Destination NAT (Port Forwarding): Forward external HTTP traffic from WAN port 80 to the Web Server in the DMZ
iptables -t nat -A PREROUTING -i $IF_WAN -p tcp --dport 80 -j DNAT --to-destination $WEB_SERVER

# =====================================================================
echo "=== IPTABLES CONFIGURATION SUCCESSFULLY APPLIED FOR ROUTER 1 ==="
