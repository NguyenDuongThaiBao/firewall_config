#!/bin/bash

# =====================================================================
# 1. VARIABLE DECLARATIONS
# =====================================================================
i=2  # Change to your group number

IF_LAN="enp0s3"   # Interface → Switch 1 → Host 1 (Corporate LAN)
IF_DMZ="enp0s8"   # Interface → direct cable → Host 2 (Web Server)
IF_WAN="enp0s9"   # Interface → Switch 2 → Internet side

LAN_NET="192.168.1${i}0.0/24"
DMZ_NET="192.168.${i}0.0/24"
WEB_SERVER="192.168.${i}0.50"

echo "=== INITIALIZING FIREWALL FOR ROUTER 1 (GROUP $i) ==="

# =====================================================================
# 2. FLUSH AND RESET
# =====================================================================
iptables -F
iptables -X
iptables -t nat -F
iptables -t nat -X
iptables -t mangle -F
iptables -t mangle -X

# =====================================================================
# 3. DEFAULT POLICIES — block everything unless explicitly allowed
# =====================================================================
iptables -P INPUT   DROP
iptables -P FORWARD DROP
iptables -P OUTPUT  DROP

# =====================================================================
# 4. LOOPBACK — router talks to itself
# =====================================================================
iptables -A INPUT  -i lo -j ACCEPT
iptables -A OUTPUT -o lo -j ACCEPT

# =====================================================================
# 5. STATEFUL INSPECTION — allow replies to established connections
# =====================================================================
iptables -A INPUT   -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
iptables -A OUTPUT  -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
iptables -A FORWARD -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

# Drop broken/invalid packets immediately
iptables -A INPUT   -m conntrack --ctstate INVALID -j DROP
iptables -A FORWARD -m conntrack --ctstate INVALID -j DROP

# =====================================================================
# 6. FIREWALL INPUT — SSH from LAN into Router 1 itself
# =====================================================================
iptables -A INPUT -i $IF_LAN -p tcp --dport 22 \
         -m conntrack --ctstate NEW -j ACCEPT

# =====================================================================
# 7. DOS PROTECTION
# =====================================================================

# SYN Flood — rate limit new TCP connections
iptables -N SYN_FLOOD
iptables -A FORWARD -p tcp --syn -j SYN_FLOOD
iptables -A SYN_FLOOD -m limit --limit 1/s --limit-burst 3 -j RETURN
iptables -A SYN_FLOOD -j DROP

# Protect Router 1 itself from SYN flood
iptables -A INPUT -p tcp --syn \
         -m limit --limit 1/s --limit-burst 3 -j ACCEPT

# Ping of Death — rate limit ALL ICMP globally
iptables -A FORWARD -p icmp -m limit --limit 5/s --limit-burst 10 -j ACCEPT
iptables -A INPUT   -p icmp -m limit --limit 5/s --limit-burst 10 -j ACCEPT

# =====================================================================
# 8. ICMP MANAGEMENT
# FIX: echo-reply only allowed going INTO LAN or DMZ
#      NOT back to internet — this was causing Host 3 to ping Host 1
# =====================================================================

# Allow essential ICMP error messages — needed for network to work
iptables -A FORWARD -p icmp --icmp-type destination-unreachable -j ACCEPT
iptables -A FORWARD -p icmp --icmp-type time-exceeded           -j ACCEPT

# FIX: echo-reply only goes back TO LAN or DMZ, never back to internet
iptables -A FORWARD -o $IF_LAN -p icmp --icmp-type echo-reply   -j ACCEPT
iptables -A FORWARD -o $IF_DMZ -p icmp --icmp-type echo-reply   -j ACCEPT

# LAN can ping freely outbound
iptables -A FORWARD -i $IF_LAN -p icmp --icmp-type echo-request -j ACCEPT

# Block internet pinging LAN
iptables -A FORWARD -i $IF_WAN -o $IF_LAN \
         -p icmp --icmp-type echo-request -j DROP

# Block DMZ pinging LAN
iptables -A FORWARD -i $IF_DMZ -o $IF_LAN \
         -p icmp --icmp-type echo-request -j DROP

# =====================================================================
# 9. LAN TRAFFIC RULES
# =====================================================================

# Block SSH from LAN to internet
iptables -A FORWARD -i $IF_LAN -o $IF_WAN \
         -p tcp --dport 22 -j DROP

# Allow SSH from LAN to DMZ
iptables -A FORWARD -i $IF_LAN -o $IF_DMZ \
         -p tcp --dport 22 -m conntrack --ctstate NEW -j ACCEPT

# Allow DNS from LAN to internet
iptables -A FORWARD -i $IF_LAN -o $IF_WAN \
         -p udp --dport 53 -j ACCEPT
iptables -A FORWARD -i $IF_LAN -o $IF_WAN \
         -p tcp --dport 53 -j ACCEPT

# Allow all other outbound traffic from LAN (HTTP, HTTPS, etc.)
iptables -A FORWARD -i $IF_LAN \
         -m conntrack --ctstate NEW -j ACCEPT

# =====================================================================
# 10. INTERNET → DMZ
# Only HTTP port 80 allowed from internet to web server
# =====================================================================
iptables -A FORWARD -i $IF_WAN -o $IF_DMZ \
         -d $WEB_SERVER -p tcp --dport 80 \
         -m conntrack --ctstate NEW -j ACCEPT

# =====================================================================
# 11. DMZ ISOLATION
# No outbound rules for DMZ = cannot initiate anything
# Handled automatically by default FORWARD DROP policy
# =====================================================================

# =====================================================================
# 12. NAT
# =====================================================================

# SNAT — hide LAN IPs behind Router 1's public IP
iptables -t nat -A POSTROUTING -o $IF_WAN \
         -s $LAN_NET -j MASQUERADE

# DNAT — redirect HTTP from internet to web server
iptables -t nat -A PREROUTING -i $IF_WAN \
         -p tcp --dport 80 -j DNAT --to-destination $WEB_SERVER

# =====================================================================
# 13. IP FORWARDING — master switch for routing
# =====================================================================
echo 1 > /proc/sys/net/ipv4/ip_forward

echo ""
echo "=== FIREWALL RULES APPLIED SUCCESSFULLY ==="
echo ""
echo "Verify with:"
echo "  sudo iptables -L FORWARD -v -n"
echo "  sudo iptables -t nat -L -v -n"
