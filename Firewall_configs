#!/bin/bash

# =====================================================================
# 1. KHAI BÁO BIẾN (BẮT BUỘC: Hãy sửa các thông số này cho đúng bài lab)
# =====================================================================
i=1  # Sửa số 1 thành số nhóm/mã số bài lab của bạn (ví dụ: i=2 nếu là mạng 192.168.120.0)

# Điền chính xác tên cổng mạng của Router 1 (Dùng lệnh 'ip a' trên Router để xem)
IF_LAN="eth1"  # Cổng nối vào vùng LAN (Corporate Network)
IF_DMZ="eth2"  # Cổng nối vào vùng DMZ (Web Server)
IF_WAN="eth0"  # Cổng nối vào Switch 2 (Hướng ra Internet)

# Các dải mạng dựa theo biến i
LAN_NET="192.168.1${i}0.0/24"
DMZ_NET="192.168.${i}0.0/24"
WEB_SERVER="192.168.${i}0.50"

echo "=== ĐANG KHỞI TẠO CẤU HÌNH IPTABLES CHO ROUTER 1 ==="

# =====================================================================
# 2. DỌN SẠCH CÁC LUẬT CŨ (RESET FIREWALL)
# =====================================================================
iptables -F
iptables -X
iptables -t nat -F
iptables -t nat -X

# =====================================================================
# 3. CHÍNH SÁCH MẶC ĐỊNH (DEFAULT POLICIES) -> DROP HẾT ĐỂ BẢO MẬT
# =====================================================================
iptables -P INPUT DROP
iptables -P FORWARD DROP
iptables -P OUTPUT DROP

# =====================================================================
# 4. QUẢN LÝ TRẠNG THÁI KẾT NỐI (STATEFUL INSPECTION)
# Tự động cho phép các gói tin phản hồi (ESTABLISHED, RELATED) đi qua
# =====================================================================
iptables -A INPUT -m conntrack --state ESTABLISHED,RELATED -j ACCEPT
iptables -A FORWARD -m conntrack --state ESTABLISHED,RELATED -j ACCEPT
iptables -A OUTPUT -m conntrack --state ESTABLISHED,RELATED -j ACCEPT

# =====================================================================
# 5. CẤU HÌNH CHO BẢN THÂN FIREWALL (INPUT / OUTPUT)
# =====================================================================
# - Tường lửa được phép giao tiếp với chính nó (giao diện Loopback)
iptables -A INPUT -i lo -j ACCEPT
iptables -A OUTPUT -o lo -j ACCEPT

# - Ngăn chặn mọi traffic khác chủ động kết nối trực tiếp đến bản thân Firewall
# (Đã được đảm bảo bởi chính sách mặc định INPUT DROP ở trên)

# =====================================================================
# 6. CẤU HÌNH LUẬT CHUYỂN TIẾP (FORWARD CHAIN) CHO CÁC VÙNG MẠNG
# =====================================================================

# --- CHỐNG TẤN CÔNG DOS / AN TOÀN MẠNG ---
# Loại bỏ ngay lập tức các gói tin có trạng thái không hợp lệ (Chống Ping of Death phân mảnh)
iptables -A FORWARD -m conntrack --state INVALID -j DROP

# Giới hạn tốc độ gói SYN để chống tấn công SYN-Flood
iptables -N SYN_FLOOD
iptables -A FORWARD -p tcp --syn -j SYN_FLOOD
iptables -A SYN_FLOOD -m limit --limit 1/s --limit-burst 3 -j RETURN
iptables -A SYN_FLOOD -j DROP


# --- DỊCH VỤ DNS ---
# Cho phép vùng LAN gửi truy vấn DNS ra các DNS Server bên ngoài Internet
iptables -A FORWARD -i $IF_LAN -o $IF_WAN -s $LAN_NET -p udp --dport 53 -m conntrack --state NEW -j ACCEPT
iptables -A FORWARD -i $IF_LAN -o $IF_WAN -s $LAN_NET -p tcp --dport 53 -m conntrack --state NEW -j ACCEPT


# --- DỊCH VỤ SSH ---
# 1. Cho phép vùng LAN kết nối SSH tới các máy trong vùng DMZ
iptables -A FORWARD -i $IF_LAN -o $IF_DMZ -s $LAN_NET -d $DMZ_NET -p tcp --dport 22 -m conntrack --state NEW -j ACCEPT

# 2. CẤM TUYỆT ĐỐI vùng LAN khởi tạo kết nối SSH ra ngoài Internet
iptables -A FORWARD -i $IF_LAN -o $IF_WAN -s $LAN_NET -p tcp --dport 22 -j DROP


# --- DỊCH VỤ WEB (HTTP/HTTPS) ---
# 1. Cho phép Internet truy cập vào Web Server trong vùng DMZ bằng cổng 80 (HTTP)
iptables -A FORWARD -i $IF_WAN -o $IF_DMZ -d $WEB_SERVER -p tcp --dport 80 -m conntrack --state NEW -j ACCEPT

# 2. Cho phép LAN khởi tạo kết nối Web (HTTP/HTTPS) ra Internet và DMZ
iptables -A FORWARD -i $IF_LAN -s $LAN_NET -p tcp --dport 80 -m conntrack --state NEW -j ACCEPT
iptables -A FORWARD -i $IF_LAN -s $LAN_NET -p tcp --dport 443 -m conntrack --state NEW -j ACCEPT


# --- QUẢN LÝ GIAO THỨC ICMP (PING & MẠNG) ---
# Cho phép các loại ICMP hợp lệ và cần thiết cho hệ thống vận hành
iptables -A FORWARD -p icmp --icmp-type destination-unreachable -j ACCEPT
iptables -A FORWARD -p icmp --icmp-type time-exceeded -j ACCEPT
iptables -A FORWARD -p icmp --icmp-type echo-reply -j ACCEPT

# Giới hạn băng thông Ping để chống DoS Ping Flood
iptables -A FORWARD -p icmp --icmp-type echo-request -m limit --limit 1/s --limit-burst 4 -j ACCEPT

# CHẶN các gói tin Ping (Echo Request) không phù hợp từ Internet chủ động thăm dò mạng LAN
iptables -A FORWARD -i $IF_WAN -o $IF_LAN -p icmp --icmp-type echo-request -j DROP


# =====================================================================
# 7. CẤU HÌNH ĐỊNH TUYẾN NAT (BẢNG NAT)
# =====================================================================
# - Source NAT (Ẩn IP nguồn): Định danh các máy LAN thành IP mặt ngoài khi ra Internet
iptables -t nat -A POSTROUTING -o $IF_WAN -s $LAN_NET -j MASQUERADE

# - Destination NAT (Port Forwarding): Chuyển hướng traffic HTTP từ ngoài vào đúng Web Server DMZ
iptables -t nat -A PREROUTING -i $IF_WAN -p tcp --dport 80 -j DNAT --to-destination $WEB_SERVER

# =====================================================================
echo "=== ĐÃ CẤU HÌNH IPTABLES THÀNH CÔNG CHO ROUTER 1 ==="
